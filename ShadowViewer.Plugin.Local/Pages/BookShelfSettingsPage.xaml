<Page
    mc:Ignorable="d"
    x:Class="ShadowViewer.Plugin.Local.Pages.BookShelfSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls1="using:ShadowViewer.Controls"
    xmlns:controls2="using:ShadowViewer.Plugin.Local.Controls"
    xmlns:converters="using:ShadowViewer.Plugin.Local.Converters"
    xmlns:converters1="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="using:ShadowViewer.Plugin.Local.Enums"
    xmlns:i18N="using:ShadowViewer.Plugin.Local.I18n"
    xmlns:icons="using:FluentIcons.WinUI"
    xmlns:icx="using:FluentIcons.WinUI.Markup"
    xmlns:local="using:ShadowViewer.Plugin.Local"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:readers="using:ShadowViewer.Plugin.Local.Readers"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <converters1:BoolNegationConverter x:Key="BoolNegationConverter" />
    </Page.Resources>
    <Grid Style="{ThemeResource ShadowRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            FontSize="{ThemeResource ShadowRootTextFontSize}"
            Grid.Row="0"
            Margin="{ThemeResource ShadowSettingRootTextMargin}"
            Text="{i18N:Locale Key=BookShelfSettings}" />
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel HorizontalAlignment="Stretch" Spacing="{StaticResource SettingsCardSpacing}">
                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                </StackPanel.ChildrenTransitions>
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="{i18N:Locale Key=ShowSetting}" />
                <controls:SettingsCard
                    Description="{i18N:Locale Key=IsBookShelfInfoBarDescription}"
                    Header="{i18N:Locale Key=IsBookShelfInfoBar}"
                    HeaderIcon="{icx:FluentIcon Icon=CalendarInfo}">
                    <ToggleSwitch
                        IsOn="{x:Bind Config.LocalIsBookShelfInfoBar, Mode=TwoWay}"
                        OffContent="{i18N:Locale Key=ShowOff}"
                        OnContent="{i18N:Locale Key=ShowOn}" />
                </controls:SettingsCard>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="{i18N:Locale Key=OperationSetting}" />
                <controls:SettingsCard
                    Description="{i18N:Locale Key=RememberDeleteWithFilesDescription}"
                    Header="{i18N:Locale Key=RememberDeleteWithFiles}"
                    HeaderIcon="{icx:FluentIcon Icon=Checkbox2}">
                    <ToggleSwitch
                        IsOn="{x:Bind Config.LocalIsRememberDeleteFilesWithComicDelete, Mode=TwoWay, Converter={StaticResource BoolNegationConverter}}"
                        OffContent="{i18N:Locale Key=NeedOff}"
                        OnContent="{i18N:Locale Key=NeedOn}" />
                </controls:SettingsCard>
                <controls:SettingsCard
                    Description="{i18N:Locale Key=DeleteWithFilesDescription}"
                    Header="{i18N:Locale Key=DeleteWithFiles}"
                    HeaderIcon="{icx:FluentIcon Icon=DeleteLines}">

                    <ToggleSwitch IsOn="{x:Bind Config.LocalIsDeleteFilesWithComicDelete, Mode=TwoWay}" />
                </controls:SettingsCard>
                <controls:SettingsCard
                    Description="{i18N:Locale Key=IsImportAgainDescription}"
                    Header="{i18N:Locale Key=IsImportAgain}"
                    HeaderIcon="{icx:FluentIcon Icon=CubeArrowCurveDown}">
                    <ToggleSwitch
                        IsOn="{x:Bind Config.LocalIsImportAgain, Mode=TwoWay}"
                        OffContent="{i18N:Locale Key=AllowOff}"
                        OnContent="{i18N:Locale Key=AllowOn}" />
                </controls:SettingsCard>
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="{i18N:Locale Key=LocalReaderSetting}" />
                <controls:SettingsCard
                    Description="{i18N:Locale Key=LocalReaderModeDescription}"
                    Header="{i18N:Locale Key=LocalReaderMode}"
                    HeaderIcon="{icx:FluentIcon Icon=BookTemplate}">
                    <controls2:EnumButton
                        EnumSource="readers:ReadingMode"
                        SelectedValue="{x:Bind Config.LocalReaderMode, Mode=TwoWay}"
                        TextConverter="{ThemeResource LocalReaderModeConverter}" />
                </controls:SettingsCard>
                <controls:SettingsCard
                    Description="{i18N:Locale Key=AllowHorizontalDragInScrollDescription}"
                    Header="{i18N:Locale Key=AllowHorizontalDragInScroll}"
                    HeaderIcon="{icx:FluentIcon Icon=PhoneSpanOut}">
                    <ToggleSwitch IsOn="{x:Bind Config.AllowHorizontalDragInScrollMode}" />
                </controls:SettingsCard>
                <controls:SettingsCard
                    Description="{i18N:Locale Key=IsFitToModeSizeDescription}"
                    Header="{i18N:Locale Key=IsFitToModeSize}"
                    HeaderIcon="{icx:FluentIcon Icon=Ruler}">
                    <ToggleSwitch IsOn="{x:Bind Config.IsFitToModeSize}" />
                </controls:SettingsCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>